# Telegram Bot Configuration
BOT_TOKEN=your_bot_token_here
ADMIN_ID=your_telegram_id_here

# Admin Panel (External)
ADMIN_API_KEY=your_secret_admin_api_key_here
ADMIN_PANEL_URL=https://your-admin-panel.up.railway.app

# External APIs
CMC_API_KEY=your_coinmarketcap_api_key_here
OXAPAY_API_KEY=your_oxapay_general_api_key_here
OXAPAY_MERCHANT_KEY=your_oxapay_merchant_api_key_here
XROCKET_API_KEY=your_xrocket_api_key_here

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/cryptexa

# Railway (auto-set by Railway, no need to configure manually)
# RAILWAY_PUBLIC_DOMAIN=your-app.up.railway.app
# RAILWAY_ENVIRONMENT=production
# PORT=auto
